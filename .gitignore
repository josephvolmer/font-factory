# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- Pipeline output ---
# Per-sheet intermediates: sliced glyphs, traced outlines, contact sheets,
# proofs. All regenerated by `make all`.
#
# No leading slash: the app once wrote its output relative to its own working
# directory, so these directories can appear at any depth. Anchoring the pattern
# to the root would have let app/build/ slip into a commit.
build/
out/

# Built fonts are regenerated from their sheets, so they are not committed.
# RandomScribble is the exception: it predates this pipeline and has no sheet
# behind it, so ignoring it would lose it permanently.
fonts/*.ttf
!fonts/RandomScribble-Regular.ttf

# Specimens rendered by `make render` / `fontfactory render`.
output.png
*.proof.png

# --- Electron app ---
node_modules/
app/dist/
app/dist-release/
app/.vite/

# --- macOS ---
.DS_Store
